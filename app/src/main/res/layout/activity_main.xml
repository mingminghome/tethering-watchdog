<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp"
            android:gravity="center_horizontal">

            <!-- Header: stacks on very narrow widths so Auto-recover isn't clipped -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tether Watchdog"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="System ready"
                        android:textSize="13sp"
                        android:textColor="#2E7D32"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/watchdogSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-recover"
                    android:textSize="12sp"
                    android:minHeight="48dp"/>
            </LinearLayout>

            <!-- USB status card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E6E8EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USB CONNECTION"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="#8A9199"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/usbStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_status_badge"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:id="@+id/usbSpeedTier"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="USB · —"
                            android:textSize="14sp"
                            android:textColor="#5F6B76"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/usbDetailText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="#5F6B76"
                        android:text="Enable Auto-recover to monitor the cable and heal the tether."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mobile radio: 4G / 4G+ / 5G step-downs while tethered -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E6E8EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOBILE RADIO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="#8A9199"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/radioStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_status_badge"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:id="@+id/radioDetailText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Checking radio…"
                            android:textSize="13sp"
                            android:textColor="#5F6B76"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/radioEventText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="#8A9199"
                        android:text="Drops are tagged: tethered · idle (no USB) · after reset · cable only.\nUnplug for a baseline — idle drops are not the USB port."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Debug metrics: live rates + light ping (foreground only) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E6E8EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DEBUG METRICS"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:textColor="#8A9199"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Live rates + light ping · app open only"
                                android:textSize="11sp"
                                android:textColor="#A0A8B0"/>
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/debugMetricsSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Debug"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/debugMetricsBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="@drawable/bg_rate_panel">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mobile (4G/5G)"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#1565C0"/>

                                <TextView
                                    android:id="@+id/mobileRateText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="↓ 0 KB/s\n↑ 0 KB/s"
                                    android:textSize="15sp"
                                    android:lineSpacingExtra="4dp"
                                    android:textColor="#1A1A1A"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>

                            <View
                                android:layout_width="10dp"
                                android:layout_height="1dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="@drawable/bg_rate_panel">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="USB tether"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#00695C"/>

                                <TextView
                                    android:id="@+id/tetherRateText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="↓ 0 KB/s\n↑ 0 KB/s"
                                    android:textSize="15sp"
                                    android:lineSpacingExtra="4dp"
                                    android:textColor="#1A1A1A"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/compareHintText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textSize="12sp"
                            android:textColor="#5F6B76"
                            android:text="Use the PC while debug is on to compare rates."/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="10dp"
                            android:background="#EEF1F4"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="INTERNET"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.06"
                                    android:textColor="#8A9199"/>

                                <TextView
                                    android:id="@+id/inetHealthText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#5F6B76"
                                    android:text="—"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="light ping"
                                android:textSize="11sp"
                                android:textColor="#A0A8B0"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/debugMetricsOffHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="12sp"
                        android:textColor="#8A9199"
                        android:text="Turn on Debug to sample mobile vs USB rates and a light ping. Stops when you leave the app."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Big circle reset -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_ripple_bg"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/manualBtn"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="RESET"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:cornerRadius="110dp"
                    app:elevation="8dp"
                    app:backgroundTint="#D32F2F"
                    app:rippleColor="#FFFFFF"/>
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:textColor="#9AA3AB"
                android:text="If status is Limited or Unstable, reseat the cable — software cannot fix a loose USB port."/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
