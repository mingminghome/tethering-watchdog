<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: USB plug + link arcs (tether) + shield (watchdog).
     Safe zone ≈ center 66dp within 108dp viewport. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body -->
    <path
        android:fillColor="@color/ic_launcher_fg"
        android:fillAlpha="0.18"
        android:pathData="M54,22
            C54,22 72,28 78,30
            C78,30 78,52 78,58
            C78,72 66,82 54,88
            C42,82 30,72 30,58
            C30,52 30,30 30,30
            C36,28 54,22 54,22 Z" />

    <!-- Shield stroke -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_fg"
        android:strokeWidth="3.2"
        android:strokeLineJoin="round"
        android:pathData="M54,26
            C54,26 69,31 74,33
            C74,33 74,52 74,57
            C74,69 64,78 54,83
            C44,78 34,69 34,57
            C34,52 34,33 34,33
            C39,31 54,26 54,26 Z" />

    <!-- USB plug body -->
    <path
        android:fillColor="@color/ic_launcher_fg"
        android:pathData="M46,40 h16 a3,3 0 0 1 3,3 v14 a3,3 0 0 1 -3,3 h-16 a3,3 0 0 1 -3,-3 v-14 a3,3 0 0 1 3,-3 z" />

    <!-- USB prongs -->
    <path
        android:fillColor="@color/ic_launcher_fg"
        android:pathData="M49,34 h3 v7 h-3 z" />
    <path
        android:fillColor="@color/ic_launcher_fg"
        android:pathData="M56,34 h3 v7 h-3 z" />

    <!-- Cable from plug -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_accent"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,60 v8" />

    <!-- Link / signal arcs (tether to host) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_accent"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:pathData="M42,70 a14,10 0 0 0 24,0" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_accent"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:pathData="M38,74 a20,13 0 0 0 32,0" />

    <!-- Watchdog check -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/ic_launcher_fg"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M45,52 L51,58 L63,44" />
</vector>
